<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        Title="心跳接收" Closing="Window_Closing"
        x:Class="QpTestClient.HeartbeatRecvForm">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top">
            <Grid ColumnDefinitions="Auto,*">
                <Label>窗口标题：</Label>
                <TextBox Name="txtFormTitle" Grid.Column="1" TextChanged="txtFormTitle_TextChanged"></TextBox>
            </Grid>
            <Grid ColumnDefinitions="Auto,*">
                <Label>显示行数：</Label>
                <StackPanel Orientation="Horizontal" Grid.Column="1">
                    <NumericUpDown Name="nudMaxLines" Value="100" MinWidth="80"></NumericUpDown>
                    <Button Name="btnStartRecv" Click="btnStartRecv_Click">开始接收</Button>
                    <Button Name="btnStopRecv" IsEnabled="False" Click="btnStopRecv_Click">停止接收</Button>
                </StackPanel>
            </Grid>
        </StackPanel>
        <TextBox Name="txtLog"></TextBox>
    </DockPanel>
</Window>
